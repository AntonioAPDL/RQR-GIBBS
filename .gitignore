# Local-only literature workspace.
literature/pdfs/*
literature/notes/*
literature/SHA256SUMS
literature/pdf_manifest.csv
!literature/pdfs/.gitkeep
!literature/notes/.gitkeep

# Local-only application outputs.
application/data_local/
application/cache/
application/runs/
application/logs/
application/outputs/
application/manifests/*.csv
application/manifests/*.json
application/manifests/*.rds
application/manifests/*.Rds
application/manifests/*.RDS
!application/manifests/README.md

